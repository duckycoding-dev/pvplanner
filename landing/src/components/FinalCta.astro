---
import type { LandingCopy } from "../i18n/types";

interface Props {
  copy: LandingCopy;
  toolUrl: string;
}
const { copy, toolUrl } = Astro.props;
---

<section class="mx-auto max-w-3xl px-4 py-20 text-center lg:py-24">
  <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{copy.finalCta.h2}</h2>
  <p class="mt-4 text-lg text-slate-600">{copy.finalCta.body}</p>
  <a
    href={toolUrl}
    class="mt-8 inline-block rounded-xl bg-accent px-8 py-4 text-lg font-bold text-slate-900 shadow-md transition hover:brightness-105"
  >
    {copy.finalCta.cta}
  </a>
  <p class="mt-3 text-sm text-slate-500 italic">{copy.finalCta.micro}</p>
</section>
