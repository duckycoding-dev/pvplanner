---
import type { LandingCopy } from "../i18n/types";

interface Props {
  copy: LandingCopy;
}
const { copy } = Astro.props;
---

<section class="bg-slate-50 py-16 lg:py-20">
  <div class="mx-auto max-w-4xl px-4">
    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">{copy.problem.h2}</h2>
    <p class="mt-4 text-lg text-slate-600">{copy.problem.intro}</p>
    <ol class="mt-8 space-y-6">
      {
        copy.problem.points.map((p, i) => (
          <li class="flex gap-4">
            <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent text-sm font-extrabold text-slate-900">
              {i + 1}
            </span>
            <p class="text-slate-600">
              <strong class="text-slate-900">{p.title}</strong> {p.body}
            </p>
          </li>
        ))
      }
    </ol>
    <p class="mt-8 border-l-4 border-accent2 pl-4 text-lg font-medium text-slate-800">
      {copy.problem.closing}
    </p>
  </div>
</section>
