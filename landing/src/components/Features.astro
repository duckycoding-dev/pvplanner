---
import type { LandingCopy } from "../i18n/types";

interface Props {
  copy: LandingCopy;
}
const { copy } = Astro.props;

// Dimensioni reali dei .webp per basename (da optimize-shots.ts), per il CLS.
const dims: Record<string, { w: number; h: number }> = {
  compare: { w: 1400, h: 875 },
  daily: { w: 1400, h: 522 },
  cashflow: { w: 1400, h: 827 },
  tariff: { w: 1000, h: 1600 },
};
const dim = (shot: string) => dims[shot.split("/").pop()!.replace(".webp", "")] ?? { w: 1400, h: 875 };
---

<section id="features" class="scroll-mt-20 bg-slate-50 py-16 lg:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">{copy.features.h2}</h2>
    <div class="mt-12 space-y-16">
      {
        copy.features.items.map((f, i) => (
          <div class={`grid items-center gap-8 lg:grid-cols-2 ${i % 2 === 1 ? "lg:[&>*:first-child]:order-2" : ""}`}>
            <div>
              <h3 class="text-xl font-bold text-slate-900">{f.title}</h3>
              <p class="mt-3 text-slate-600">{f.body}</p>
            </div>
            <img
              src={f.shot}
              alt={f.alt}
              width={dim(f.shot).w}
              height={dim(f.shot).h}
              loading="lazy"
              class="block w-full rounded-xl border border-slate-200 shadow-md"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
