---
import type { LandingCopy } from "../i18n/types";

interface Props {
  copy: LandingCopy;
}
const { copy } = Astro.props;
---

<section id="not-modeled" class="mx-auto max-w-4xl scroll-mt-20 px-4 py-16 lg:py-20">
  <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">{copy.notModeled.h2}</h2>
  <p class="mt-4 text-lg text-slate-600">{copy.notModeled.intro}</p>
  <ul class="mt-8 space-y-5">
    {
      copy.notModeled.points.map((p) => (
        <li class="rounded-xl border border-slate-200 p-5">
          <p class="text-slate-600">
            <strong class="text-slate-900">{p.title}</strong> {p.body}
          </p>
        </li>
      ))
    }
  </ul>
  <p class="mt-8 text-slate-600">{copy.notModeled.closing}</p>
</section>
