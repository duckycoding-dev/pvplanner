---
import type { Lang, LandingCopy } from "../i18n/types";

interface Props {
  copy: LandingCopy;
  lang: Lang;
}
const { copy, lang } = Astro.props;

// Dimensioni reali dei wizard-N.webp generati da scripts/screenshots.ts + optimize-shots.ts.
const dims = [
  { w: 1000, h: 1080 },
  { w: 1000, h: 1600 },
  { w: 1400, h: 875 },
];
---

<section id="how" class="mx-auto max-w-6xl scroll-mt-20 px-4 py-16 lg:py-20">
  <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">{copy.how.h2}</h2>
  <div class="mt-10 grid gap-8 md:grid-cols-3">
    {
      copy.how.steps.map((s, i) => (
        <div class="flex flex-col rounded-2xl border border-slate-200 p-6">
          <span class="text-4xl font-extrabold text-accent">{i + 1}</span>
          <h3 class="mt-3 text-lg font-bold text-slate-900">{s.title}</h3>
          <p class="mt-2 text-sm text-slate-600">{s.body}</p>
          {s.privacyNote && <p class="mt-3 text-sm text-slate-500 italic">{s.privacyNote}</p>}
          <img
            src={`/shots/${lang}/wizard-${i + 1}.webp`}
            alt={s.title}
            width={dims[i].w}
            height={dims[i].h}
            loading="lazy"
            class="mt-4 block w-full rounded-lg border border-slate-100"
          />
        </div>
      ))
    }
  </div>
</section>
