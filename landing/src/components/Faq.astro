---
import type { LandingCopy } from "../i18n/types";

interface Props {
  copy: LandingCopy;
}
const { copy } = Astro.props;
---

<section id="faq" class="mx-auto max-w-3xl scroll-mt-20 px-4 py-16 lg:py-20">
  <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">{copy.faq.h2}</h2>
  <div class="mt-8 divide-y divide-slate-200 border-y border-slate-200">
    {
      copy.faq.items.map((item) => (
        <details class="group py-4">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
            <h3 class="text-base font-bold text-slate-900">{item.q}</h3>
            <span class="text-accent transition group-open:rotate-45" aria-hidden="true">
              +
            </span>
          </summary>
          <p class="mt-3 text-slate-600">{item.a}</p>
        </details>
      ))
    }
  </div>
</section>
