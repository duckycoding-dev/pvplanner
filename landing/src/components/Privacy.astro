---
import type { LandingCopy } from "../i18n/types";

interface Props {
  copy: LandingCopy;
}
const { copy } = Astro.props;
---

<section id="privacy" class="scroll-mt-20 bg-slate-900 py-16 text-white lg:py-20">
  <div class="mx-auto max-w-5xl px-4">
    <h2 class="text-3xl font-extrabold tracking-tight">{copy.privacy.h2}</h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-2">
      {
        copy.privacy.points.map((p) => (
          <div class="flex gap-3">
            <span class="mt-1 text-accent" aria-hidden="true">
              ✓
            </span>
            <p class="text-slate-300">
              <strong class="text-white">{p.title}</strong> {p.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
