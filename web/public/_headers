# Cloudflare Pages headers. Applicati a tutte le risposte statiche.
# NB CSP: 'sha256-...' in script-src copre lo script inline di analytics in index.html.
#   Se modifichi quello snippet, ricalcola l'hash con:
#     bun -e 'const h=await Bun.file("dist/index.html").text();const m=h.match(/<script>([\s\S]*?)<\/script>/);console.log("sha256-"+new Bun.CryptoHasher("sha256").update(m[1]).digest("base64"))'
#   (il token analytics vive nel <meta name="cf-analytics-token">, quindi cambiarlo NON cambia l'hash).
# style-src 'unsafe-inline': richiesto dagli inline styles di Recharts.
# connect-src: cloudflareinsights.com per il beacon analytics (cookieless) e
#   nominatim.openstreetmap.org per la ricerca località del wizard (fetch diretta dal browser).
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com 'sha256-Ii0NoFBIaIOrnFkQ7tO3uWQAOME1OOF+8ZqhY1Ivdy8='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloudflareinsights.com https://nominatim.openstreetmap.org; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'
